######################################################
# IQ1.0 - Initial Question 1.0: Vehicle brought into NI from EU  #
######################################################

vehicleFromEu.title = Are you completing a notification for a vehicle brought into Northern Ireland from an EU country?
vehicleFromEu.heading = Are you completing a notification for a vehicle brought into Northern Ireland from an EU country?
vehicleFromEu.checkYourAnswersLabel = Vehicle brought into Northern Ireland from an EU country
vehicleFromEu.error.required = Select yes if the vehicle was brought into Northern Ireland from an EU country
vehicleFromEu.change.hidden = vehicle brought into Northern Ireland from an EU country

######################################################
# IQ1.1 - Initial Question 1.1: Vehicle brought into NI from outside EU  #
######################################################

vehicleOutsideEU.title = If you’ve brought a vehicle into Northern Ireland from outside the EU
vehicleOutsideEU.heading = If you’ve brought a vehicle into Northern Ireland from outside the EU
vehicleOutsideEU.paragraph.1 = Find out how to notify HMRC about it on {0}.
vehicleOutsideEU.paragraph.2 = See the list of the {0}.

######################################################
# BY1.0 - Before you continue  - Individual                        #
######################################################

beforeYouContinue.title = Before you continue
beforeYouContinue.heading = Before you continue
beforeYouContinue.body.1 = To use this service, you need the following information.
beforeYouContinue.vehicle.body = For each vehicle, you need:
beforeYouContinue.vehicle.list.1 = Vehicle Identification Number (VIN)
beforeYouContinue.vehicle.list.2 = current vehicle registration number
beforeYouContinue.vehicle.list.3 = import entry number, if applicable (for each import entry)
beforeYouContinue.vehicle.list.4 = date the vehicle arrived in the UK
beforeYouContinue.vehicle.list.5 = mileage
beforeYouContinue.vehicle.list.6 = total price paid
beforeYouContinue.supplier.body = For each vehicle supplier, you need:
beforeYouContinue.supplier.list.1 = the name and address
beforeYouContinue.supplier.list.2 = VAT registration number (if applicable)
beforeYouContinue.updating.heading = Updating vehicle notifications
beforeYouContinue.updating.body.1 = To update a notification, you need to create and submit a new one to replace your previous submission.
beforeYouContinue.updating.body.2 = You need the notification reference. You can find this in the message we sent after you submitted.

######################################################
# BY2.0 - Before you continue - Organisation and Agent  #
######################################################

beforeYouContinueOrg.title = Before you continue
beforeYouContinueOrg.heading = Before you continue
beforeYouContinueOrg.body.1 = To use this service, you need the following information.
beforeYouContinueOrg.vehicle.body = For each vehicle, you need:
beforeYouContinueOrg.vehicle.list.1 = Vehicle Identification Number (VIN)
beforeYouContinueOrg.vehicle.list.2 = current vehicle registration number
beforeYouContinueOrg.vehicle.list.3 = import entry number, if applicable (for each import entry)
beforeYouContinueOrg.vehicle.list.4 = date the vehicle arrived in the UK
beforeYouContinueOrg.vehicle.list.5 = mileage
beforeYouContinueOrg.vehicle.list.6 = total price paid
beforeYouContinueOrg.supplier.body = For each vehicle supplier, you need:
beforeYouContinueOrg.supplier.list.1 = the name and address
beforeYouContinueOrg.supplier.list.2 = VAT registration number (if applicable)
beforeYouContinueOrg.updating.heading = Updating vehicle notifications
beforeYouContinueOrg.updating.body.1 = To update a notification, you need to create and submit a new one to replace your previous submission.
beforeYouContinueOrg.updating.body.2 = You need the notification reference. You can find this in the message we sent after you submitted.
beforeYouContinueOrg.multiple.heading = Notifying for multiple vehicles
beforeYouContinueOrg.multiple.body.1 = If you’re completing notifications for multiple vehicles brought into the UK, you do not need to enter details for each vehicle one by one.
beforeYouContinueOrg.multiple.body.2 = You can use a vehicle spreadsheet to enter details for up to 100 vehicles, then upload the completed spreadsheet with your notification.
beforeYouContinueOrg.multiple.link.text = Find the spreadsheet (opens in new tab)
beforeYouContinueOrg.multiple.body.3 = you need for the type of vehicles you’ve brought into the UK.

