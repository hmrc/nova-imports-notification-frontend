GET         /check-answers/your-details                             controllers.YourDetailsCheckYourAnswersController.onPageLoad()
POST        /check-answers/your-details                             controllers.YourDetailsCheckYourAnswersController.onSubmit()

GET         /check-answers/purchaser-details                        controllers.PurchaserDetailsCheckYourAnswersController.onPageLoad()
